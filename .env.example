# SurvivalRAG Configuration
# Copy to .env and uncomment to override defaults
# Reference: docker-compose.yml

# LLM model for response generation (default: llama3.1:8b)
# Must be available in your Ollama instance
# SURVIVALRAG_MODEL=llama3.1:8b

# Ollama server URL (default: http://ollama:11434 in Docker, http://localhost:11434 natively)
# Set to point to an external Ollama instance (e.g., GPU machine on LAN)
# OLLAMA_HOST=http://192.168.1.100:11434

# Maximum chunks to retrieve per query (default: 5)
# SURVIVALRAG_MAX_CHUNKS=5

# Cosine similarity threshold for relevance filtering (default: 0.25)
# Lower values return more results; higher values are stricter
# SURVIVALRAG_RELEVANCE_THRESHOLD=0.25

# Cross-encoder reranker model (default: BAAI/bge-reranker-v2-m3)
# Improves retrieval precision 15-40% by re-scoring query+document pairs together
# Requires: pip install sentence-transformers
# Set to empty string or "none" to disable
# SURVIVALRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
