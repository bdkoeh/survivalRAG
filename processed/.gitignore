# Extracted section files are pipeline output -- regenerated by:
#   python pipeline/extract_all.py
# They are not committed to avoid bloating the repo (7900+ files).
# Run the extraction pipeline locally to produce them.
sections/*/
!sections/.gitkeep

# Corrections are human-authored and SHOULD be committed
!corrections/

# Reports are pipeline output
reports/*/
!reports/.gitkeep
